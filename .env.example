# Supabase — browser app (Vite). Copy to .env
# Never put the service_role key in VITE_* variables; it is exposed in the JS bundle.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Production URL for password reset links (e.g., https://your-app.vercel.app)
# In development, this will fallback to window.location.origin
VITE_APP_URL=https://your-production-domain.com

# Optional local flag for future dev-only UI
VITE_DEV_MODE=true

# Admin Auth (create/delete users) from your machine only — NOT Vite:
# Copy scripts/env.admin.example to .env.admin in the project root (gitignored).
# Then: npm run admin:create-user -- email@x.com 'Password' '{}'

# Admin Auth (create/delete users) from your machine only — NOT Vite:
